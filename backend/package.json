{
  "name": "aura-backend",
  "version": "1.0.0",
  "description": "Backend API for Aura product traceability",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:watch": "NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --watch --runInBand",
    "test:coverage": "NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --coverage --runInBand",
    "test:ipfs": "node test-ipfs.js"
  },
  "keywords": [
    "blockchain",
    "api",
    "avalanche"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
